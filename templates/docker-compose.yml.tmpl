services:

  app:
    image: {{SERVICE_IMAGE}}
    container_name: swiftdeploy-app

    environment:
      - MODE={{MODE}}
      - APP_VERSION={{APP_VERSION}}
      - APP_PORT={{SERVICE_PORT}}


    cap_drop:
      - ALL

    security_opt:
      - no-new-privileges:true

    expose:
      - "{{SERVICE_PORT}}"

    volumes:
      - {{LOGS_VOLUME}}:/app/logs

    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:{{SERVICE_PORT}}/healthz"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

    restart: {{RESTART_POLICY}}

    networks:
      - {{NETWORK_NAME}}

  nginx:
    image: {{NGINX_IMAGE}}
    container_name: swiftdeploy-nginx

    ports:
      - "{{NGINX_PORT}}:{{NGINX_PORT}}"

    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro

    depends_on:
      app:
        condition: service_healthy

    restart: {{RESTART_POLICY}}

    networks:
      - {{NETWORK_NAME}}

volumes:
  {{LOGS_VOLUME}}:

networks:
  {{NETWORK_NAME}}:
    driver: {{NETWORK_DRIVER}}